---
import { siteConfig } from "../config";
---

<div
  id="hero"
  class="relative isolate overflow-hidden min-h-screen flex items-center"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <!-- Dark background with subtle pattern -->
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full"
    style="opacity: 0.03"
  >
    <defs>
      <pattern
        id="hero-grid"
        x="0"
        y="0"
        width="200"
        height="200"
        patternUnits="userSpaceOnUse"
      >
        <path d="M.5 200V.5H200" fill="none" stroke="white" stroke-width="0.5"></path>
      </pattern>
      <pattern
        id="hero-symbols"
        x="0"
        y="0"
        width="400"
        height="400"
        patternUnits="userSpaceOnUse"
      >
        <text x="50" y="50" fill="white" font-family="monospace" font-size="24" transform="rotate(-15)">&lt;/&gt;</text>
        <text x="150" y="100" fill="white" font-family="monospace" font-size="20" transform="rotate(10)">{}</text>
        <text x="250" y="80" fill="white" font-family="monospace" font-size="18" transform="rotate(-5)">=&gt;</text>
        <text x="100" y="200" fill="white" font-family="monospace" font-size="22" transform="rotate(15)">[]</text>
        <text x="300" y="180" fill="white" font-family="monospace" font-size="20" transform="rotate(-10)">&lt;&gt;</text>
        <text x="200" y="250" fill="white" font-family="monospace" font-size="24" transform="rotate(5)">()</text>
        <text x="50" y="320" fill="white" font-family="monospace" font-size="18" transform="rotate(-8)">::</text>
        <text x="350" y="300" fill="white" font-family="monospace" font-size="22" transform="rotate(12)">==</text>
        <text x="150" y="350" fill="white" font-family="monospace" font-size="20" transform="rotate(-15)">++</text>
        <text x="250" y="370" fill="white" font-family="monospace" font-size="24" transform="rotate(8)">;</text>
      </pattern>
    </defs>
    <rect fill="url(#hero-symbols)" width="100%" height="100%" opacity="0.5"></rect>
    <rect fill="url(#hero-grid)" width="100%" height="100%" stroke-width="0"></rect>
  </svg>

  <div class="relative z-10 w-full mx-auto p-8 sm:p-12 md:p-24">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
      <!-- Text Content -->
      <div class="flex-1 order-2 lg:order-1 text-center lg:text-left">
        <h2
          class="text-pretty text-xl sm:text-2xl md:text-3xl font-bold tracking-tight animate-fade-in-up"
          style="color: var(--text-secondary)"
        >
          Hello! 👋
        </h2>
        <h1
          class="mt-4 sm:mt-6 text-pretty text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-bold tracking-tight animate-fade-in-up delay-200"
          style="color: var(--text-primary)"
        >
          I'm <span style={{ color: siteConfig.accentColor }}>{siteConfig.name}</span>
        </h1>
        <p
          class="mt-4 sm:mt-6 text-pretty text-lg sm:text-xl md:text-2xl font-medium animate-fade-in-up delay-400 typing-cursor"
          style="color: var(--text-muted)"
        >
          {siteConfig.title}
        </p>

        <!-- Social Links -->
        <div class="mt-8 sm:mt-10 flex gap-x-5 sm:gap-x-6 justify-center lg:justify-start animate-fade-in-up delay-600">
          {
            siteConfig.social?.email && (
              <a
                href={`mailto:${siteConfig.social.email}`}
                aria-label="Email"
                class="social-icon"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-7 sm:w-7">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
                  <path d="M3 7l9 6l9 -6" />
                </svg>
              </a>
            )
          }
          {
            siteConfig.social?.linkedin && (
              <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-7 sm:w-7">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <path d="M8 11v5" />
                  <path d="M8 8v.01" />
                  <path d="M12 16v-5" />
                  <path d="M16 16v-3a2 2 0 1 0 -4 0" />
                  <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" />
                </svg>
              </a>
            )
          }
          {
            siteConfig.social?.twitter && (
              <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="social-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-7 sm:w-7">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <path d="M4 4l11.733 16h4.267l-11.733 -16z" />
                  <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772" />
                </svg>
              </a>
            )
          }
          {
            siteConfig.social?.github && (
              <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="social-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-7 sm:w-7">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
                </svg>
              </a>
            )
          }
          {
            siteConfig.social?.whatsapp && (
              <a href={siteConfig.social.whatsapp} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="social-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-7 sm:w-7">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9" />
                  <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1" />
                </svg>
              </a>
            )
          }
        </div>
      </div>

      <!-- Profile Photo -->
      <div class="flex-shrink-0 order-1 lg:order-2 animate-fade-in-up delay-300">
        <div class="relative">
          <!-- Glow ring -->
          <div class="absolute -inset-2 rounded-full opacity-60" style={`background: linear-gradient(135deg, ${siteConfig.accentColor}, #00D9FF, ${siteConfig.accentColor}); filter: blur(20px);`}></div>
          <!-- Glass border -->
          <div class="relative rounded-full p-1" style={`background: linear-gradient(135deg, ${siteConfig.accentColor}80, rgba(255,255,255,0.1), ${siteConfig.accentColor}80);`}>
            <img
              src="/profile.png"
              alt={`${siteConfig.name} — ${siteConfig.title}`}
              class="w-48 h-48 sm:w-56 sm:h-56 md:w-64 md:h-64 lg:w-72 lg:h-72 rounded-full object-cover profile-glow"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
