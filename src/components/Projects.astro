---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="relative z-10 p-8 sm:p-12 md:p-16 lg:p-24">
      <div class="reveal">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl section-heading">
              Projects
            </h2>
            <div class="section-accent-bar" />
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-6 sm:space-y-8">
              {siteConfig.projects.map((project, index) => {
                const Component = project.link ? "a" : "div";
                const linkProps = project.link
                  ? {
                      href: project.link,
                      target: "_blank",
                      rel: "noopener noreferrer",
                    }
                  : {};

                return (
                  <div class="group relative">
                    <Component
                      {...linkProps}
                      class="block relative p-5 sm:p-6 md:p-8 glass-card glow-hover rounded-xl sm:rounded-2xl cursor-pointer"
                    >
                      {project.link && (
                        <div class="absolute top-4 right-4 sm:top-6 sm:right-6 md:top-8 md:right-8 w-10 h-10 sm:w-11 sm:h-11 flex items-center justify-center rounded-full transition-all duration-300"
                          style={`background: var(--glass-bg); border: 1px solid var(--glass-border);`}>
                          <svg
                            class="w-4 h-4 sm:w-5 sm:h-5 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            style="color: var(--accent)"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M7 17L17 7M17 7H7M17 7V17"
                            />
                          </svg>
                        </div>
                      )}

                      <div class="space-y-4">
                        <div>
                          <span
                            class="text-sm font-mono"
                            style="color: var(--accent)"
                          >
                            0{index + 1}
                          </span>
                          <h3 class="text-xl sm:text-2xl font-bold mt-1" style="color: var(--text-primary)">
                            {project.name}
                          </h3>
                        </div>

                        <p
                          class={`text-base sm:text-lg leading-relaxed ${project.link ? "pr-12 sm:pr-14" : ""}`}
                          style="color: var(--text-secondary)"
                        >
                          {project.description}
                        </p>

                        {project.skills && project.skills.length > 0 && (
                          <div class="flex flex-wrap gap-2 pt-2">
                            {project.skills.map((skill) => (
                              <span class="tech-badge">
                                {skill}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                    </Component>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
