---
import { siteConfig } from "../config";
---

<section id="about" class="relative z-10 p-8 sm:p-12 md:p-16 lg:p-24">
  <div class="reveal">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
      <div class="lg:col-span-4">
        <h2 class="text-3xl sm:text-4xl md:text-5xl section-heading">
          About Me
        </h2>
        <div class="section-accent-bar"></div>
      </div>

      <div class="lg:col-span-8 space-y-8">
        <div class="glass-card rounded-2xl p-6 sm:p-8">
          <p class="text-base sm:text-lg md:text-xl leading-relaxed" style="color: var(--text-secondary)">
            {siteConfig.aboutMe}
          </p>
        </div>

        <div class="pt-2">
          <h3 class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: var(--accent)">
            Skills & Technologies
          </h3>
          <div class="flex flex-wrap gap-2.5 sm:gap-3">
            {
              siteConfig.skills.map((skill) => (
                <span class="skill-pill">
                  {skill}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
